# ────────────────────────────────────────────────────────────
#  YEHLI — Variables d'environnement (exemple)
#  Copier ce fichier en « .env » puis renseigner les valeurs.
# ────────────────────────────────────────────────────────────

# ── Base de données (PostgreSQL) ─────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/yehli_db?schema=public"

# ── NextAuth ─────────────────────────────────────────
# Générer un secret : `openssl rand -base64 32` ou `npx auth secret`
NEXTAUTH_SECRET="generate-a-strong-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Administrateur (utilisé par le seed Prisma) ──────
ADMIN_EMAIL="admin@yehli.org"
ADMIN_PASSWORD="YehliAdmin2024!"

# ── Email (Resend) ───────────────────────────────────
# Sans clé, les emails sont journalisés en console (mode dégradé).
RESEND_API_KEY=""
EMAIL_FROM="YEHLI <noreply@yehli.org>"
ADMIN_NOTIFICATION_EMAIL="contact@yehli.org"

# ── Upload médias (UploadThing) ──────────────────────
UPLOADTHING_TOKEN=""
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# ── Site public ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Paiement (abstraction — compléter selon prestataire) ──
PAYMENT_PROVIDER=""           # cinetpay | paydunya | stripe | fedapay | mtn_momo
PAYMENT_API_KEY=""
PAYMENT_SECRET=""
PAYMENT_WEBHOOK_SECRET=""

# ── Rate limiting optionnel (Upstash Redis) ──────────
# Sans ces variables, un limiteur en mémoire est utilisé.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
